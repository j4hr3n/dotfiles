#!/usr/bin/env bash

set -e

# Check if running on macOS
if [[ "$OSTYPE" != "darwin"* ]]; then
    echo "Error: This script is for macOS only."
    echo "For other platforms, please use the appropriate setup script."
    exit 1
fi

# Redirect to the Mac-specific setup script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# If running from a cloned repo, use the local script
if [ -f "$SCRIPT_DIR/setup-mac.sh" ]; then
    exec "$SCRIPT_DIR/setup-mac.sh"
else
    # Otherwise, download and run from GitHub
    exec bash -c "$(curl -fsSL https://raw.githubusercontent.com/j4hr3n/dotfiles/main/setup-mac.sh)"
fi
